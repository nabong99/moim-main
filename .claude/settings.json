{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npx create-next-app@latest:*)",
      "Bash(npm install:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run build:*)",
      "Bash(npx shadcn@latest:*)",
      "Bash(supabase init:*)",
      "Bash(supabase link:*)",
      "Bash(supabase orgs create:*)",
      "Bash(supabase projects create:*)",
      "Bash(supabase projects api-keys:*)",
      "Bash(supabase migration new:*)",
      "Bash(supabase db push:*)",
      "Bash(supabase db diff:*)",
      "Bash(supabase migration repair:*)",
      "Bash(supabase config push:*)",
      "Bash(vercel link:*)",
      "Bash(vercel env add:*)",
      "Bash(vercel env ls:*)",
      "Bash(vercel deploy:*)",
      "Bash(vercel git connect:*)",
      "Bash(vercel inspect:*)",
      "Bash(gh repo create:*)",
      "Bash(gh repo view:*)",
      "Bash(gh auth status:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push origin main)",
      "Bash(git remote add:*)",
      "Bash(git remote -v)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(cat:*)",
      "Bash(node --version)",
      "Bash(npm --version)",
      "Bash(mkdir:*)",
      "WebFetch(domain:supabase.com)",
      "WebFetch(domain:vercel.com)",
      "WebFetch(domain:nextjs.org)",
      "WebFetch(domain:ui.shadcn.com)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git checkout -- .)",
      "Bash(git restore --source:*)",
      "Bash(supabase db reset:*)",
      "Bash(supabase projects delete:*)",
      "Bash(supabase orgs delete:*)",
      "Bash(vercel remove:*)",
      "Bash(vercel projects rm:*)",
      "Bash(gh repo delete:*)",
      "Bash(npm uninstall:*)"
    ]
  }
}
